{
    "arrowParens": "avoid",
    "printWidth": 120,
    "proseWrap": "never",
    "trailingComma": "es5",
    "tabWidth": 4,
    "endOfLine": "lf",
    "bracketSpacing": true,
    "semi": true,
    "importOrder": ["^react$", "^next", "<THIRD_PARTY_MODULES>", "^@/(.*)$", "^[./]"],
    "importOrderSeparation": true,
    "importOrderSortSpecifiers": true,
    "plugins": ["prettier-plugin-tailwindcss"]
}
